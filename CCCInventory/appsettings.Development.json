{
  "Jwt": {
    "SecretKey": "dev-only-secret-key-not-for-production-use-32chars+extra",
    "Issuer": "CCCInventory",
    "Audience": "CCCInventory",
    "ExpiryDays": 30
  },
  "Security": {
    "InactivityTimeoutMinutes": 5,
    "InitialAdminPassword": "admin123",
    "ForceResetAdminPassword": false
  },
  // NOTE: Jwt:SecretKey is dev-only. Production must use the Jwt__SecretKey environment variable.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore.SpaProxy": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
